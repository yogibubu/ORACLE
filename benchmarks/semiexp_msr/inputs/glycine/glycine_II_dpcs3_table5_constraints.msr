#m symmetry=isotopes coordinate=cartesian structure=re source=McGlone1999_Kasalova2007_DPCS3
#d niso=10
! Glycine conformer II / gly(2), MSR-compatible Cartesian SE benchmark.
! Geometry: non-Cs DPCS3 Cartesian structure supplied by the user.
! Atom order follows the DPCS3 geometry used by the new SEfit runs:
! 1 carboxyl C, 2 hydroxyl O, 3 carbonyl O, 4 hydroxyl H,
! 5 methylene C, 6 amino N, 7-8 methylene H, 9-10 amino H.
! B0 constants and weights follow the glycine microwave data set used for the
! Kasalova et al. comparison. dbvib rows are the Gly-IIn zero-point
! corrections (Ae-A0, Be-B0, Ce-C0). The five constraints reproduce the
! Table 5 functional form, but the target values are evaluated from the DPCS3
! starting geometry using Gaussian GIC Value= syntax.

C    -0.605409    0.048618    0.008294
O    -0.466207   -1.283076    0.040998
O    -1.672626    0.597583   -0.065929
H     0.498731   -1.438884    0.086538
C     0.713796    0.816690    0.100999
N     1.864651   -0.072827   -0.071081
H     0.738859    1.262069    1.097259
H     0.667972    1.637619   -0.617124
H     2.630486    0.180667    0.537016
H     2.210109   -0.053398   -1.021716

constraints
RCH7=R(5,7)
RCH8=R(5,8)
RNH9=R(6,9)
RNH10=R(6,10)
ACH8N=A(8,5,6)
ACH8C=A(8,5,1)
ACH7N=A(7,5,6)
ACH7C=A(7,5,1)
DN10CC=D(10,6,5,1)
DN9CC=D(9,6,5,1)
DRCH(Frozen,Value=0.000091749296)=RCH8-RCH7
DRNH(Frozen,Value=0.001425022132)=RNH10-RNH9
CH2ROCK(Frozen,Value=5.952336039351)=ACH8N+ACH8C-ACH7N-ACH7C
CH2TWIST(Frozen,Value=3.372267118858)=ACH8N-ACH8C-ACH7N+ACH7C
HNCCAV(Frozen,Value=-44.452723919609)=DN10CC+DN9CC
end

