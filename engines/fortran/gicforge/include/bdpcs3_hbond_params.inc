      DOUBLE PRECISION BDPCS3_HB_SEARCH_CUTOFF
      DOUBLE PRECISION BDPCS3_HB_DELTA_OO
      DOUBLE PRECISION BDPCS3_HB_DELTA_NN
      DOUBLE PRECISION BDPCS3_W_STRETCH
